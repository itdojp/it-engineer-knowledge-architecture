{
  "name": "it-engineer-knowledge-architecture",
  "version": "1.0.0",
  "private": true,
  "description": "Catalog and publishing governance for the IT Engineer Knowledge Architecture book lineup",
  "scripts": {
    "generate": "node scripts/generate-catalog-derived.mjs && node scripts/report-catalog-debt.mjs --write",
    "check:generated": "node scripts/generate-catalog-derived.mjs --check && npm run check:catalog-debt",
    "report:catalog-debt": "node scripts/report-catalog-debt.mjs",
    "check:catalog-debt": "node scripts/report-catalog-debt.mjs --check",
    "test:catalog-debt": "node --test tests/catalog-debt.test.mjs",
    "validate:catalog": "node scripts/validate-catalog.mjs",
    "check:catalog-completion": "node scripts/check-catalog-completion.mjs",
    "test:catalog-completion": "node --test tests/catalog-completion.test.mjs",
    "validate:learning-graph": "node scripts/validate-learning-graph.mjs",
    "test:fixtures": "node scripts/test-catalog-fixtures.mjs",
    "verify": "npm run verify:catalog && npm run test:production-smoke && npm run test:pages-drift && npm run build:site && npm run test:e2e",
    "verify:catalog": "npm run validate:catalog && npm run check:catalog-completion && npm run validate:learning-graph && npm run check:generated && npm run test:fixtures && npm run test:catalog-debt && npm run test:catalog-completion && npm run test:portfolio-health",
    "build:site": "rm -rf .site && jekyll build --source docs --destination .site/it-engineer-knowledge-architecture --baseurl /it-engineer-knowledge-architecture",
    "test:e2e": "playwright test",
    "test:production-smoke": "node --test tests/smoke-production.test.mjs",
    "test:pages-drift": "node --test tests/pages-drift.test.mjs",
    "report:portfolio-health": "node scripts/portfolio-health-cli.mjs",
    "test:portfolio-health": "node --test tests/portfolio-health.test.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1"
  }
}
